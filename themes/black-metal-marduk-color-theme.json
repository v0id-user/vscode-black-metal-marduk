  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#626b67",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "foreground": "#a5aaa7"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#c1c1c1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#c1c1c1"
      }
    },
    {
      "name": "Variable language (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types, classes, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.struct",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Tag attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#a5aaa7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys / properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "Namespaces / modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.import",
        "storage.modifier.package"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#5f8787",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#626b67",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#c1c1c1"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#c1c1c1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c1c1c1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c1c1c1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#aaaaaa",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#a5aaa7"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#626b67",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#a5aaa7"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#626b67"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#a5aaa7"
      }
    }
  ]
}
